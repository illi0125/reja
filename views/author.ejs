<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/main.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
    <title>Portfolio</title>
  </head>
  <body>
    <div class="frame">
      <div class="main_frame">
        <!-- LEFT FRAME START -->
        <div class="left_frame">
          <!-- left_1 -->
          <div class="left_1">
            <div class="left_1-1">
              <img
                src="images/Profile.png"
                width="156px"
                height="142px"
                alt="Profile picture"
              />
            </div>
            <div class="left_1-2"><%=user.name%></div>
            <div class="left_1-3"><%=user.profession%></div>
            <div class="left-icons">
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Facebook.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Instagram.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Twitter.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Linkeding.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Youtube.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Dribbble.svg" class="icon-1" alt="" />
                </div>
              </a>
            </div>
          </div>
          <div class="marginer"></div>
          <!-- left_3 -->
          <div class="left_2">
            <div class="left_2-1">
              <span style="background: #ffb400; width: 46.21px">Age:</span>
              <span><%=user.age%></span>
            </div>
            <div class="left_2-1">
              <span style="background: #ffb400; width: 82px">Residence:</span>
              <span><%=user.residence%></span>
            </div>
            <div class="left_2-1">
              <span style="background: #ffb400; width: 80px">Freelance:</span>
              <span style="color: rgb(128, 203, 128)">Available</span>
            </div>
            <div class="left_2-1">
              <span style="background: #ffb400; width: 75px">Address:</span>
              <span><%=user.adress%></span>
            </div>
          </div>
          <div class="marginer"></div>
          <!-- left_3 -->
          <div class="left_3">
            <div class="languages">Languages</div>
            <div class="bangla">
              <span><%=user.languages[0]%></span>
              <span>100%</span>
            </div>
            <div class="lan-border"></div>
            <div class="bangla">
              <span><%=user.languages[1]%></span>
              <span>80%</span>
            </div>
            <div class="lan-border" style="width: 205px"></div>
            <div class="bangla">
              <span><%=user.languages[2]%></span>
              <span>60%</span>
            </div>
            <div class="lan-border" style="width: 190px"></div>
          </div>
          <div class="marginer"></div>
          <!-- left_4 -->
          <div class="left_4">
            <div class="languages">Skills</div>
            <div class="bangla">
              <span><%=user.skills[0]%></span>
              <span>90%</span>
            </div>
            <div class="lan-border" style="width: 205px"></div>
            <div class="bangla">
              <span><%=user.skills[1]%></span>
              <span>85%</span>
            </div>
            <div class="lan-border" style="width: 195px"></div>
            <div class="bangla">
              <span><%=user.skills[2]%></span>
              <span>80%</span>
            </div>
            <div class="lan-border" style="width: 190px"></div>
            <div class="bangla">
              <span><%=user.skills[3]%></span>
              <span>75%</span>
            </div>
            <div class="lan-border" style="width: 185px"></div>
            <div class="bangla">
              <span><%=user.skills[4]%></span>
              <span>85%</span>
            </div>
            <div
              class="lan-border"
              style="width: 205px"
              style="width: 195px"
            ></div>
          </div>
          <div class="marginer"></div>
          <!-- left_5 -->
          <div class="left_5">
            <div class="languages">Extra Skills</div>
            <div class="bangla">
              <img src="icon/Icons.svg" style="margin-right: 6px" alt="" />
              <span><%=user.extra_skills[0]%></span>
            </div>
            <div class="bangla">
              <img src="icon/Icons.svg" style="margin-right: 6px" alt="" />
              <span><%=user.extra_skills[1]%></span>
            </div>
            <div class="bangla">
              <img src="icon/Icons.svg" style="margin-right: 6px" alt="" />
              <span><%=user.extra_skills[2]%></span>
            </div>
            <div class="bangla">
              <img src="icon/Icons.svg" style="margin-right: 6px" alt="" />
              <span><%=user.extra_skills[3]%></span>
            </div>
          </div>
          <div class="marginer"></div>
        </div>
        <!-- LEFT FRAME END -->
        <!-- MIDD FRAME START -->
        <div class="midd_frame">
          <!-- midd_top -->
          <div class="midd_top">
            <div class="midd_top_div">
              <div class="midd_top_frame">
                <!-- round -->
                <div class="round_yellow"></div>
                <div class="round_green"></div>
                <div class="round_yellow_1"></div>
                <div class="round_green_1"></div>
                <div class="rectangle_yellow"></div>
                <div class="rectangle_blue"></div>
                <div class="rectangle_blue_1"></div>
                <div class="triangle_red"></div>
                <!-- round end -->
                <div class="midd_top_main_text">
                  Doctor neurologists in OHSU Hospital
                </div>
                <div class="midd_top_text">
                  <p>
                    Lorem, ipsum dolor sit amet consectetur adipisicing elit.
                    Molestias ab id excepturi optio recusandae deleniti aut
                    tempora ut odit odio veniam eos voluptates, dolorum
                    corrupti?
                  </p>
                </div>
                <a href="" class="link_href">
                  <button>
                    HIRE ME <i class="fa-solid fa-arrow-right"></i>
                  </button>
                </a>
              </div>
              <div class="midd_top_img">
                <img src="images/midd_top_img.png" alt="" />
              </div>
            </div>
          </div>
          <!-- midd_bot -->
          <div class="midd_bot">
            <div class="midd_bot_div">
              <div class="midd_bot_1">
                <div class="my_services">My Services</div>
                <div class="my_services_desc">
                  Lorem ipsum dolor sit, amet consectetur adipisicing elit.
                  Corporis repellendus magni libero dicta, pariatur suscipit ea
                  porro. Nam, omnis repudiandae.
                </div>
              </div>
              <div class="midd_bot_2">
                <div class="midd_bot_2_box">
                  <img src="images/coding.png" alt="" />
                  <strong>Web Development</strong>
                  <span>Blog, E-Commerce</span>
                </div>
                <div class="midd_bot_2_box">
                  <img src="images/illustration.png" alt="" />
                  <strong>UI/UX Design</strong>
                  <span>Mobile App, Website Design</span>
                </div>
                <div class="midd_bot_2_box">
                  <img src="images/illustration.png" alt="" />
                  <strong>UI/UX Design</strong>
                  <span>Mobile App, Website Design</span>
                </div>
                <div class="midd_bot_2_box">
                  <img src="images/Microphone.png" alt="" />
                  <strong>Sound Design</strong>
                  <span>Voice Over, Beat Making</span>
                </div>
                <div class="midd_bot_2_box">
                  <img src="images/game-development.png" alt="" />
                  <strong>UI/UX Design</strong>
                  <span>Mobile App, Website Design</span>
                </div>
                <div class="midd_bot_2_box">
                  <strong>Advertising</strong>
                  <span style="width: 260px; text-align: center"
                    >Lorem ipsum, dolor sit amet consectetur adipisicing elit.
                    Porro, nesciunt.</span
                  >
                  <button>
                    ORDER NOW <i class="fa-solid fa-angle-right"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- MIDD FRAME END -->
        <!-- RIGHT FRAME START -->
        <div class="right_frame">
          <img src="icon/Contrast.svg" style="margin-top: 35px" alt="" />
          <img
            src="icon/Pop up.svg"
            style="position: absolute; margin-top: 230px"
            alt=""
          />
          <div class="right_frame_main">
            <img src="icon/Home.svg" alt="" />
            <img src="icon/Service.svg" alt="" />
            <img src="icon/Cv.svg" alt="" />
            <img src="icon/Portfolio.svg" alt="" />
            <img src="icon/Blog.svg" alt="" />
            <img src="icon/Contact.svg" alt="" />
          </div>
        </div>
        <!-- RIGHT FRAME END -->
      </div>
    </div>
  </body>
</html>
