<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>REJA</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
      .form_back {
        background-color: #ffffff;
        border: #d1d5db;
        border-radius: 10px;
        margin-bottom: 20px;
      }
      .title {
        font-weight: bold;
        letter-spacing: 1px;
      }
      .btn-sm {
        border-radius: 20px;
      }
      #clean-al {
        border-radius: 30px;
        margin-top: 20px;
        width: 100%;
      }
    </style>
  </head>
  <body style="background-color: #f8fafc">
    <div class="container">
      <h1 class="display-4 text-center py-1 title">📌 REJA VA MAQSADLAR</h1>

      <div class="jumbotron p-3 shadow-sm form_back">
        <form id="create-form" action="/create-item" method="POST">
          <div class="d-flex align-items-center">
            <input
              id="create-field"
              name="reja"
              autofocus
              autocomplete="off"
              class="form-control mr-3"
              type="text"
              style="flex: 1"
            />
            <button class="btn btn-primary" style="border-radius: 20px">
              Yangi Reja Qoshish
            </button> 
            <!-- STEP 2: From Frontend to Backend -->
          </div>
        </form>
      </div>

      <ul id="item-list" class="list-group pb-5">
        <% items.map(function(item) { %> 
        <li class="list-group-item list-group-item-info d-flex align-items-center justify-content-between">
          <span class="item-text"><%=item.reja%></span>
          <div>
            <button data-id="<%=item._id%>" class="edit-me btn btn-secondary btn-sm mr-1">
              Ozgartirish
            </button>
            <button data-id="<%=item._id%>" class="delete-me btn btn-danger btn-sm">Ochirish</button>
          </div>
        </li>
        <% }) %>
        
      </ul>

      <button id="clean-al" class="btn btn-danger" style="border-radius: 20px">
        <i class="fa-solid fa-trash-can" style="color: white;"></i>
        <b>Delete all plans</b>
      </button>
    </div>

    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
    <script src="/browser.js"></script>
  </body>
</html>
